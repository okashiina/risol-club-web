{
  "name": "risol-club",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');const path=require('node:path');for (const target of ['.next','dist-next','playwright-report','test-results','.next-start.log','.next-start.err.log']) { const full=path.join(process.cwd(), target); if (fs.existsSync(full)) fs.rmSync(full,{recursive:true,force:true}); }\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed"
  },
  "dependencies": {
    "@vercel/blob": "^2.3.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "postgres": "^3.4.8",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
