DATABASE_URL=postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require

SELLER_EMAIL=owner@example.com
SELLER_PASSWORD=replace-with-a-strong-password
SELLER_SESSION_SECRET=replace-with-a-strong-random-secret

# Optional:
# In development, this lets the database bootstrap from your local data/store.json
# instead of the seed snapshot. In production, the default bootstrap mode is "seed".
STORE_DATABASE_BOOTSTRAP=file
